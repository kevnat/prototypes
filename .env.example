# Database Configuration
# Possible values: 'supabase' | 'mysql'
# If not set, defaults to 'mysql' in development, 'supabase' in production
VITE_DATABASE_PROVIDER=supabase

# Supabase Configuration (for production)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# MySQL Configuration (for local development)
VITE_MYSQL_HOST=localhost
VITE_MYSQL_PORT=3306
VITE_MYSQL_USER=root
VITE_MYSQL_PASSWORD=
VITE_MYSQL_DATABASE=prototypes

# Jira proxy credentials (server-side only — never expose to client)
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your_api_token_here